# Logs

# =========================

*.log

# =========================

# Data (IMPORTANT)

# =========================

# Raw datasets (DO NOT COMMIT)

data/raw/

# Large intermediate datasets

data/interim/*.parquet
data/interim/*.csv

# Optional: if you generate large experiment outputs

data/experiments/*.parquet
data/experiments/*.csv

# =========================

# Models / artifacts

# =========================

models/
*.pkl
*.joblib

# =========================

# Temporary files

# =========================

*.tmp
*.temp

# =========================

# Keep important outputs

# =========================

# Allow figures to be committed

!reports/figures/
!reports/figures/**/*.png

# Allow diagrams

!reports/diagrams/
!reports/diagrams/**/*.png

# Allow small tables if any

!reports/tables/
